<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07001A" > <ImageView
    android:id="@+id/imgLogo"
    android:layout_width="280dp"
    android:layout_height="140dp"
    android:src="@drawable/carro_lateral"
    android:layout_centerInParent="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/imgLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:fontFamily="monospace"
        android:text="SENSOR DRIVE"
        android:textColor="#00FFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:shadowColor="#FF44FF"
        android:shadowDx="0" android:shadowDy="0" android:shadowRadius="15" />

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        android:indeterminateTint="#FFEE00" />

</RelativeLayout>